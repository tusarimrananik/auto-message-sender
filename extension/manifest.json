{
  "manifest_version": 3,
  "name": "AutoChat MVP",
  "version": "1.0.0",
  "description": "Local scripted two-profile chat automation MVP.",
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "https://*.messenger.com/*",
    "https://messenger.com/*",
    "https://*.facebook.com/*",
    "https://facebook.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "AutoChat MVP",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:3000/test-chat.html*",
        "http://127.0.0.1:3000/test-chat.html*",
        "https://*.messenger.com/*",
        "https://messenger.com/*",
        "https://*.facebook.com/*",
        "https://facebook.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
